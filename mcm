#include <iostream>
#include <vector>
#include <climits>
#include <string>
using namespace std;

// ─────────────────────────────────────────────────────────────
//  Reconstruct optimal parenthesization by BACKTRACKING dp[][]
//  No split table stored — we re-derive the split on the fly
// ─────────────────────────────────────────────────────────────
string backtrack(const vector<vector<long long>>& dp,
                 const vector<int>& dims,
                 int i, int j, char base = 'A') {

    if (i == j)
        return string(1, base + i - 1);   // base case: single matrix

    // Try every k and find the one that matches dp[i][j]
    for (int k = i; k < j; k++) {
        long long cost = dp[i][k]
                       + dp[k + 1][j]
                       + (long long)dims[i-1] * dims[k] * dims[j];

        if (cost == dp[i][j]) {           // ← this k is the optimal split
            string left  = backtrack(dp, dims, i,     k, base);
            string right = backtrack(dp, dims, k + 1, j, base);
            return "(" + left + " x " + right + ")";
        }
    }

    return "?";  // never reached
}

// ─────────────────────────────────────────────────────────────
//  Core DP — only builds dp[][], no split table
// ─────────────────────────────────────────────────────────────
long long matrixChainOrder(const vector<int>& dims) {
    int n = dims.size() - 1;

    vector<vector<long long>> dp(n + 1, vector<long long>(n + 1, 0));

    for (int l = 2; l <= n; l++) {
        for (int i = 1; i <= n - l + 1; i++) {
            int j = i + l - 1;
            dp[i][j] = LLONG_MAX;

            for (int k = i; k < j; k++) {
                long long cost = dp[i][k]
                               + dp[k + 1][j]
                               + (long long)dims[i-1] * dims[k] * dims[j];

                if (cost < dp[i][j])
                    dp[i][j] = cost;     // no split[i][j] = k  ← removed!
            }
        }
    }

    // Print DP table
    cout << "\nDP Table:\n";
    cout << "       ";
    for (int j = 1; j <= n; j++) cout << "  [" << j << "]   ";
    cout << "\n";
    for (int i = 1; i <= n; i++) {
        cout << "  [" << i << "]  ";
        for (int j = 1; j <= n; j++) {
            if      (j < i)  cout << "   -   ";
            else if (j == i) cout << "   0   ";
            else             cout.width(7), cout << dp[i][j];
        }
        cout << "\n";
    }

    // Backtrack to find parenthesization WITHOUT split table
    cout << "\nBacktracking dp[][] to find optimal split...\n";
    cout << "Optimal parenthesization: " << backtrack(dp, dims, 1, n) << "\n";
    cout << "Minimum multiplications : " << dp[1][n] << "\n";

    return dp[1][n];
}

int main() {
    cout << "═══════════════════════════════════════\n";
    cout << " Example 1 — 3 Matrices\n";
    cout << " A(10x30)  B(30x5)  C(5x60)\n";
    cout << "═══════════════════════════════════════";
    matrixChainOrder({10, 30, 5, 60});

    cout << "\n═══════════════════════════════════════\n";
    cout << " Example 2 — 4 Matrices\n";
    cout << " A(40x20)  B(20x30)  C(30x10)  D(10x30)\n";
    cout << "═══════════════════════════════════════";
    matrixChainOrder({40, 20, 30, 10, 30});

    cout << "\n═══════════════════════════════════════\n";
    cout << " Example 3 — 5 Matrices\n";
    cout << " A(10x20)  B(20x30)  C(30x40)  D(40x30)  E(30x10)\n";
    cout << "═══════════════════════════════════════";
    matrixChainOrder({10, 20, 30, 40, 30, 10});

    return 0;
}
